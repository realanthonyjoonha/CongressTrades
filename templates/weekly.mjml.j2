{% extends "_shell.mjml.j2" %}
{#
  weekly.mjml.j2 — Weekly Deep Research email.
  Similar structure to daily but with a different banner (flagged count,
  benchmark hit rate) to reflect the weekly retrospective angle.
#}

{% block body %}

    <!-- Top banner: week summary -->
    <mj-section background-color="#161b22" padding="16px 24px">
      <mj-column>
        <mj-text align="center" font-size="13px" color="#8b949e">
          <strong class="accent">{{ counts.flagged | default(0) }}</strong> trades flagged ·
          <strong class="accent">{{ counts.beat_spy_pct | default('—') }}</strong> beat SPY ·
          <span class="tier-badge tier-STRONG">{{ counts.STRONG | default(0) }} STRONG</span>
        </mj-text>
      </mj-column>
    </mj-section>

    <!-- Main content -->
    <mj-section background-color="#0d1117" padding="24px">
      <mj-column>
        <mj-text>
          <div class="md-body">
          {{ body_html | safe }}
          </div>
        </mj-text>
      </mj-column>
    </mj-section>

{% endblock %}
