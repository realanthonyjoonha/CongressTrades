{#
  _shell.mjml.j2 — shared header/footer shell for all agent emails.
  Individual templates (daily, weekly, deepdive) extend this and fill
  the `body` block. Defines the CongressTrades brand: dark theme,
  accent colors, fixed-width content, footer with disclaimer.
#}
<mjml>
  <mj-head>
    <mj-title>{{ subject | default('CongressTrades Report') }}</mj-title>
    <mj-preview>{{ preview_text | default('') }}</mj-preview>

    <mj-attributes>
      <mj-all font-family="-apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif" />
      <mj-text color="#e6edf3" font-size="14px" line-height="1.6" padding="0 0 12px 0" />
      <mj-section background-color="#0d1117" padding="0" />
      <mj-column padding="0" />
      <mj-divider border-color="#21262d" border-width="1px" padding="16px 0" />
      <mj-button background-color="#58a6ff" color="#0d1117" inner-padding="10px 20px" font-weight="600" border-radius="6px" />
    </mj-attributes>

    <mj-style>
      /* Custom CSS that survives email clients — scoped carefully */
      body { background-color: #0d1117; margin: 0; }
      .muted { color: #8b949e; }
      .accent { color: #58a6ff; }

      /* Signal tier badges */
      .tier-badge {
        display: inline-block;
        padding: 2px 10px;
        border-radius: 12px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
      .tier-STRONG { background-color: #238636; color: #ffffff; }
      .tier-BASE { background-color: #1f6feb; color: #ffffff; }
      .tier-MODERATE { background-color: #656d76; color: #ffffff; }
      .tier-SKIP { background-color: #30363d; color: #8b949e; }

      /* Markdown-rendered content */
      .md-body h2 {
        color: #58a6ff;
        font-size: 18px;
        font-weight: 600;
        margin-top: 28px;
        margin-bottom: 12px;
        padding-bottom: 6px;
        border-bottom: 1px solid #21262d;
      }
      .md-body h3 {
        color: #e6edf3;
        font-size: 16px;
        font-weight: 600;
        margin-top: 20px;
        margin-bottom: 8px;
      }
      .md-body p { color: #e6edf3; margin: 8px 0; line-height: 1.6; }
      .md-body ul, .md-body ol { color: #e6edf3; padding-left: 20px; margin: 8px 0; }
      .md-body li { margin: 4px 0; line-height: 1.6; }
      .md-body strong { color: #ffffff; font-weight: 700; }
      .md-body em { color: #8b949e; font-style: italic; }
      .md-body a { color: #58a6ff; text-decoration: none; }
      .md-body code {
        background-color: #161b22;
        color: #79c0ff;
        padding: 1px 6px;
        border-radius: 4px;
        font-family: 'SF Mono', Menlo, Consolas, monospace;
        font-size: 12px;
      }
      .md-body blockquote {
        border-left: 3px solid #30363d;
        padding-left: 12px;
        margin: 12px 0;
        color: #8b949e;
        font-style: italic;
      }

      /* Tables */
      .md-body table {
        border-collapse: collapse;
        width: 100%;
        margin: 12px 0;
        font-size: 13px;
      }
      .md-body th {
        background-color: #161b22;
        color: #58a6ff;
        text-align: left;
        padding: 8px 12px;
        border-bottom: 2px solid #30363d;
        font-weight: 600;
      }
      .md-body td {
        padding: 8px 12px;
        border-bottom: 1px solid #21262d;
        color: #e6edf3;
      }
      .md-body tr:nth-child(even) td {
        background-color: #0d1117;
      }
      .md-body tr:nth-child(odd) td {
        background-color: #161b22;
      }
    </mj-style>
  </mj-head>

  <mj-body background-color="#0d1117" width="680px">

    <!-- Header -->
    <mj-section background-color="#161b22" padding="24px 0" border-bottom="1px solid #21262d">
      <mj-column>
        <mj-text align="center" font-size="22px" font-weight="700" color="#58a6ff" padding-bottom="4px">
          CongressTrades
        </mj-text>
        <mj-text align="center" font-size="12px" color="#8b949e" padding-top="0">
          {{ agent_label | default('Signal Report') }} · {{ date_display }}
        </mj-text>
      </mj-column>
    </mj-section>

    {% block body %}{% endblock %}

    <!-- Footer -->
    <mj-section background-color="#0d1117" padding="24px 24px 16px 24px">
      <mj-column>
        <mj-divider />
        <mj-text font-size="11px" color="#6e7681" align="center" line-height="1.6">
          Generated by the CongressTrades {{ agent_label | default('agent') }}.<br/>
          Tracks publicly-disclosed congressional stock trades filed under the STOCK Act.<br/>
          Disclosure lag up to 45 days from transaction. AI-generated for research and educational purposes only.<br/>
          Not financial advice. Do your own due diligence.
        </mj-text>
      </mj-column>
    </mj-section>

  </mj-body>
</mjml>
